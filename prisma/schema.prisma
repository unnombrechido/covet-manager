generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Brands {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  created_at  DateTime @default(now())

  houses Houses[]
}

model Houses {
  id          Int      @id @default(autoincrement())
  brand_id    Int
  name        String
  description String?
  created_at  DateTime @default(now())

  brand       Brands         @relation(fields: [brand_id], references: [id])
  members     Members[]
  directivos  Directivos[]
}

model Members {
  id            Int      @id @default(autoincrement())
  house_id      Int
  cuenta        String
  nombre        String
  activo        Boolean  @default(true)
  fecha_ingreso DateTime
  fecha_salida  DateTime?
  created_at    DateTime @default(now())

  house         Houses         @relation(fields: [house_id], references: [id])
  directivos    Directivos[]
  participations Participations[]
}

model Directivos {
  id         Int      @id @default(autoincrement())
  house_id   Int
  member_id  Int
  role       String
  start_date DateTime @default(now())
  end_date   DateTime?

  house      Houses   @relation(fields: [house_id], references: [id])
  member     Members  @relation(fields: [member_id], references: [id])
}

model Rallies {
  id            Int      @id @default(autoincrement())
  brand_id      Int?
  month         String
  rally_number  Int
  start_day     Int
  end_day       Int
  slot_ini      String?
  slot_fin      String?
  created_at    DateTime @default(now())

  brand         Brands?  @relation(fields: [brand_id], references: [id])
  shows         Shows[]
}

model Shows {
  id            Int      @id @default(autoincrement())
  rally_id      Int
  show_number   Int
  name          String
  details       String?

  rally         Rallies        @relation(fields: [rally_id], references: [id])
  participations Participations[]
}

model Participations {
  id         Int      @id @default(autoincrement())
  member_id  Int
  show_id    Int
  status     String   @default("Participated")
  points     Int      @default(0)
  notes      String?
  updated_at DateTime @default(now())

  member     Members  @relation(fields: [member_id], references: [id])
  show       Shows    @relation(fields: [show_id], references: [id])
}