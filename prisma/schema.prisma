generator client {
  provider = "prisma-client-js"
  // Remove the output line to use the default generation path (recommended for simplicity)
}

datasource db {
  provider = "postgresql"
}

// Your models here (e.g., Brands, Houses, etc. from introspect)
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model brands {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)

  houses  houses[]
  rallies rallies[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model directivos {
  id         Int       @id @default(autoincrement())
  house_id   Int?
  member_id  Int?
  role       String
  start_date DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  end_date   DateTime? @db.Date

  houses  houses?  @relation(fields: [house_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  members members? @relation(fields: [member_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model houses {
  id          Int       @id @default(autoincrement())
  brand_id    Int?
  name        String
  description String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)

  directivos directivos[]
  brands     brands?      @relation(fields: [brand_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  members    members[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model members {
  id            Int       @id @default(autoincrement())
  house_id      Int?
  cuenta        String
  nombre        String
  activo        Boolean?  @default(true)
  fecha_ingreso DateTime  @db.Date
  fecha_salida  DateTime? @db.Date
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  user_id       String?   @db.Uuid

  directivos     directivos[]
  houses         houses?          @relation(fields: [house_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  participations participations[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model participations {
  id         Int       @id @default(autoincrement())
  member_id  Int?
  show_id    Int?
  status     String?
  points     Int?      @default(0)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  notes      String?

  members members? @relation(fields: [member_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  shows   shows?   @relation(fields: [show_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model rallies {
  id           Int       @id @default(autoincrement())
  brand_id     Int?
  month        String
  rally_number Int
  start_day    Int
  end_day      Int
  slot_ini     String?
  slot_fin     String?
  created_at   DateTime? @default(now()) @db.Timestamp(6)

  brands brands? @relation(fields: [brand_id], references: [id], onUpdate: NoAction)
  shows  shows[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model shows {
  id          Int       @id @default(autoincrement())
  rally_id    Int?
  show_number Int
  name        String
  details     String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)

  participations participations[]
  rallies        rallies?         @relation(fields: [rally_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}
